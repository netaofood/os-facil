# OS Fácil — variáveis de ambiente
# Copie este arquivo para ".env" e preencha com os dados do seu projeto Supabase.
# (Settings → API no painel do Supabase)
# Estas duas chaves são públicas e seguras para o front. NUNCA coloque aqui a service_role key.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-public-key
